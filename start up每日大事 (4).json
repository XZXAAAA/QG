    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  let text = item.json.translatedText || '';\n  \n  // 清理HTML实体\n  text = text\n    .replace(/&#39;/g, \"'\")\n    .replace(/&quot;/g, '\"')\n    .replace(/&amp;/g, '&');\n  \n  // 按字段标签拆分，重新加上空行\n  text = text\n    .replace(/(Date:)/g, '\\n\\n$1')\n    .replace(/(Category:)/g, '\\n\\n$1')\n    .replace(/(Market:)/g, '\\n\\n$1')\n    .replace(/(Content:)/g, '\\n\\n$1');\n  \n  return {\n    json: {\n      ...item.json,\n      translatedText: text.trim()\n    }\n  };\n});"
      },
