    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// 解析每个item的文本，提取字段\nconst parseItem = (text) => {\n  const get = (key) => {\n    const regex = new RegExp(`\"${key}\":\\\\s*\"([^\"]*(?:\\\\\\\\.[^\"]*)*)\"`, 'i');\n    const match = text.match(regex);\n    return match ? match[1].replace(/\\\\\"/g, '\"').replace(/\\\\n/g, ' ').trim() : '';\n  };\n  return {\n    title:    get('Title'),\n    date:     get('Date'),\n    category: get('Category'),\n    market:   get('Market'),\n    content:  get('Content'),\n  };\n};\n\n// 收集所有条目\nconst allEntries = [];\nfor (const item of items) {\n  const text = item.json.text || item.json.translatedText || JSON.stringify(item.json);\n  const parsed = parseItem(text);\n  if (parsed.title) allEntries.push(parsed);\n}\n\n// 按 Category 分组\nconst grouped = {};\nfor (const entry of allEntries) {\n  const cat = entry.category || 'Unknown';\n  if (!grouped[cat]) grouped[cat] = [];\n  grouped[cat].push(entry);\n}\n\n// 输出：每个 category 一个 item\nreturn Object.entries(grouped).map(([category, entries]) => ({\n  json: {\n    category,\n    count: entries.length,\n    entries,\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
