FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-llm-api-key-here
LLM_CHAT_MODEL=qwen-plus

MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS_JSON=["-y", "@ansvar/chinese-law-mcp"]
MCP_TRANSPORT=streamable_http
MCP_SERVER_URL=https://chinese-law-mcp.vercel.app/mcp

FARUI_ENDPOINT=farui.cn-hangzhou.aliyuncs.com
FARUI_REGION_ID=cn-hangzhou
FARUI_APP_ID=farui
FARUI_WORKSPACE_ID=default
FARUI_ACCESS_KEY_ID=
FARUI_ACCESS_KEY_SECRET=
FARUI_ACCESS_KEY_FILE=
FARUI_DEFAULT_DEEP_THINK=1
FARUI_DEFAULT_ONLINE_SEARCH=1
FARUI_USE_MODEL_FALLBACK=1
FARUI_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
FARUI_MODEL_API_KEY=
FARUI_MODEL_NAME=farui-plus

# 企查查 API 凭证（可选）
QICHACHA_KEY=
QICHACHA_SECRET=
QICHACHA_BASE_URL=https://api.qichacha.com
QCC_PROXY=

# n8n 新闻 webhook（可选，已被 Python pipeline 替代）
N8N_NEWS_ENABLED=0
N8N_NEWS_WEBHOOK_URL=
N8N_NEWS_AUTH_TOKEN=
N8N_NEWS_TIMEOUT_SEC=15

# 每日新闻 pipeline（Python 原生实现）
NEWS_DEEPSEEK_API_KEY=your-deepseek-api-key-here
NEWS_DEEPSEEK_BASE_URL=https://api.deepseek.com
NEWS_DEEPSEEK_MODEL=deepseek-chat
NEWS_PIPELINE_ENABLED=1
NEWS_CACHE_TTL_DAYS=7
NEWS_CACHE_DB_PATH=
